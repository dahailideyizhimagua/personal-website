---
import PageLayout from '../layouts/PageLayout.astro';
import SectionTitle from '../components/shared/SectionTitle.astro';
import GridBackground from '../components/layout/GridBackground.astro';
---

<PageLayout title="联系 | Portfolio" description="联系方式">
  <GridBackground class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <SectionTitle number="05" label="Get In Touch" title="联系我" align="center" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-12">
        {/* Contact Info */}
        <div class="space-y-8">
          <div>
            <p class="text-text-secondary mb-6">
              无论是建筑工程信息化、WebCAD 协同设计，还是全栈 Web 开发，
              欢迎讨论合作机会或技术交流。
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-border flex items-center justify-center flex-shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="M2 4L12 13L22 4" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs uppercase tracking-wider text-text-tertiary mb-1">Email</p>
                <a href="mailto:hello@example.com" class="text-text-primary hover:text-accent-blue transition-colors">
                  hello@example.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-border flex items-center justify-center flex-shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs uppercase tracking-wider text-text-tertiary mb-1">GitHub</p>
                <a href="https://github.com" target="_blank" rel="noopener" class="text-text-primary hover:text-accent-blue transition-colors">
                  github.com/username
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-border flex items-center justify-center flex-shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect x="2" y="9" width="4" height="12" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs uppercase tracking-wider text-text-tertiary mb-1">LinkedIn</p>
                <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-text-primary hover:text-accent-blue transition-colors">
                  linkedin.com/in/username
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* Contact Form */}
        <div class="border border-border p-6 bg-white">
          <form class="space-y-4" action="https://formspree.io/f/your-form-id" method="POST">
            <div>
              <label class="block font-mono text-xs uppercase tracking-wider text-text-tertiary mb-2" for="name">
                姓名
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-border bg-bg-primary text-text-primary font-sans text-sm
                       focus:outline-none focus:border-accent-blue transition-colors"
              />
            </div>

            <div>
              <label class="block font-mono text-xs uppercase tracking-wider text-text-tertiary mb-2" for="email">
                邮箱
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-border bg-bg-primary text-text-primary font-sans text-sm
                       focus:outline-none focus:border-accent-blue transition-colors"
              />
            </div>

            <div>
              <label class="block font-mono text-xs uppercase tracking-wider text-text-tertiary mb-2" for="subject">
                主题
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 border border-border bg-bg-primary text-text-primary font-sans text-sm
                       focus:outline-none focus:border-accent-blue transition-colors"
              />
            </div>

            <div>
              <label class="block font-mono text-xs uppercase tracking-wider text-text-tertiary mb-2" for="message">
                消息
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-border bg-bg-primary text-text-primary font-sans text-sm
                       focus:outline-none focus:border-accent-blue transition-colors resize-none"
              />
            </div>

            <button type="submit" class="btn-primary w-full justify-center">
              发送消息
            </button>
          </form>
        </div>
      </div>
    </div>
  </GridBackground>
</PageLayout>

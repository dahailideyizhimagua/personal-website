---
import PageLayout from '../layouts/PageLayout.astro';
import GridBackground from '../components/layout/GridBackground.astro';
---

<PageLayout title="404 | 页面未找到" description="页面不存在">
  <GridBackground class="min-h-[80vh] flex items-center justify-center">
    <div class="text-center px-6">
      <p class="font-mono text-8xl text-accent-blue mb-4">404</p>
      <p class="font-mono text-sm uppercase tracking-wider text-text-tertiary mb-8">
        ERROR: DRAWING NOT FOUND
      </p>
      <h1 class="font-serif text-3xl text-text-primary mb-4">页面未找到</h1>
      <p class="text-text-secondary mb-8">
        您请求的图纸不在存档中。请检查地址是否正确。
      </p>
      <a href="/" class="btn-primary">
        返回首页
      </a>
    </div>
  </GridBackground>
</PageLayout>

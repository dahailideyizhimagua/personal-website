---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import SectionTitle from '../../components/shared/SectionTitle.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const categoryLabels: Record<string, string> = {
  web: 'Web 应用',
  cad: 'CAD 工具',
  opensource: '开源',
  design: '设计',
};
---

<PageLayout title="项目 | Portfolio" description="项目作品展示">
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <SectionTitle number="01" label="Selected Works" title="项目作品" />

      {/* Filter buttons */}
      <div class="flex flex-wrap gap-3 mb-12" id="filter-bar">
        <button class="filter-btn active font-mono text-xs uppercase tracking-wider px-4 py-2 border border-accent-blue bg-accent-blue text-white" data-category="all">
          全部
        </button>
        {Object.entries(categoryLabels).map(([key, label]) => (
          <button class="filter-btn font-mono text-xs uppercase tracking-wider px-4 py-2 border border-border text-text-secondary hover:border-accent-blue hover:text-accent-blue transition-colors" data-category={key}>
            {label}
          </button>
        ))}
      </div>

      {/* Project grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="project-grid">
        {projects.map(({ slug, data: { title, description, tech, category, heroImage, year } }) => (
          <a
            href={`/projects/${slug}`}
            class="card blueprint-corners group"
            data-category={category}
          >
            <div class="aspect-[16/10] bg-bg-tertiary mb-4 overflow-hidden">
              {heroImage ? (
                <img src={heroImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#B8B5AF" stroke-width="1">
                    <rect x="4" y="4" width="40" height="40" />
                    <line x1="4" y1="4" x2="44" y2="44" />
                    <line x1="44" y1="4" x2="4" y2="44" />
                    <circle cx="24" cy="24" r="8" />
                  </svg>
                </div>
              )}
            </div>

            <div class="flex items-center gap-3 mb-3">
              <span class="font-mono text-xs px-2 py-0.5 bg-accent-blue/10 text-accent-blue">
                {categoryLabels[category] || category}
              </span>
              <span class="font-mono text-xs text-text-tertiary">{year}</span>
            </div>

            <h3 class="font-serif text-xl text-text-primary mb-2 group-hover:text-accent-blue transition-colors">
              {title}
            </h3>
            <p class="text-sm text-text-secondary mb-4 line-clamp-2">{description}</p>

            <div class="flex flex-wrap gap-2">
              {tech.slice(0, 4).map(t => (
                <span class="font-mono text-xs px-2 py-0.5 border border-grid-line text-text-tertiary">
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const filterBar = document.getElementById('filter-bar');
  const grid = document.getElementById('project-grid');
  const buttons = filterBar?.querySelectorAll('.filter-btn');
  const cards = grid?.querySelectorAll('[data-category]');

  filterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-btn');
    if (!btn) return;

    const category = btn.dataset.category;

    // Update active button
    buttons?.forEach(b => {
      b.classList.remove('active', 'bg-accent-blue', 'text-white');
      b.classList.add('text-text-secondary');
    });
    btn.classList.add('active', 'bg-accent-blue', 'text-white');
    btn.classList.remove('text-text-secondary');

    // Filter cards
    cards?.forEach(card => {
      const el = card as HTMLElement;
      if (category === 'all' || el.dataset.category === category) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  });
</script>

---
const stats = [
  { value: '5+', label: '项目完成' },
  { value: '3+', label: '年开发经验' },
  { value: '10+', label: '技术栈' },
  { value: '3+', label: '技术博文' },
];
---

<section class="py-20 bg-bg-secondary">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map(({ value, label }) => (
        <div class="text-center">
          <p class="font-serif text-4xl md:text-5xl text-text-primary mb-2">{value}</p>
          <p class="font-mono text-xs uppercase tracking-wider text-text-tertiary">{label}</p>
        </div>
      ))}
    </div>

    {/* Connecting dimension line */}
    <div class="mt-8 relative h-px">
      <div class="absolute inset-0 bg-grid-strong" />
      <div class="absolute left-0 top-0 w-px h-3 bg-grid-strong -translate-y-1" />
      <div class="absolute right-0 top-0 w-px h-3 bg-grid-strong -translate-y-1" />
      {stats.slice(1, -1).map((_, i) => (
        <div
          class="absolute top-0 w-px h-3 bg-grid-strong -translate-y-1"
          style={`left: ${((i + 1) / (stats.length - 1)) * 100}%`}
        />
      ))}
    </div>
  </div>
</section>

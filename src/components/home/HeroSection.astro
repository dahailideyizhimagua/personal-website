---
import GridBackground from '../layout/GridBackground.astro';
---

<GridBackground class="min-h-screen flex items-center relative overflow-hidden">
  {/* Corner annotations */}
  <div class="absolute top-6 left-6 font-mono text-xs text-text-tertiary hidden md:block">
    SHEET 01 OF 05
  </div>
  <div class="absolute top-6 right-6 font-mono text-xs text-text-tertiary hidden md:block">
    SCALE: AS NOTED
  </div>
  <div class="absolute bottom-6 left-6 font-mono text-xs text-text-tertiary hidden md:block">
    DWG NO. P-001
  </div>
  <div class="absolute bottom-6 right-6 font-mono text-xs text-text-tertiary hidden md:block">
    DATE: 2026.05
  </div>

  <div class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    {/* Left: Text Content */}
    <div class="space-y-8">
      <div>
        <p class="font-mono text-sm text-accent-blue tracking-wider mb-4">
          ARCHITECTURAL ENGINEER / FULL-STACK DEVELOPER
        </p>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-text-primary leading-tight">
          Building<br/>
          <span class="text-accent-blue">Digital</span><br/>
          Spaces
        </h1>
      </div>

      <p class="text-lg text-text-secondary max-w-lg leading-relaxed">
        从事建筑工程与全栈开发的交叉领域，专注于构建 WebCAD 协同设计平台。
        用代码建造数字世界，用建筑思维设计软件架构。
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="btn-primary">
          查看项目
        </a>
        <a href="/blog" class="btn-secondary">
          阅读博客
        </a>
      </div>

      {/* Tech badges */}
      <div class="flex flex-wrap gap-2 pt-4">
        {['Nuxt 4', 'Vue', 'TypeScript', 'WebRTC', 'Electron'].map(tech => (
          <span class="font-mono text-xs px-3 py-1 border border-grid-line text-text-tertiary">
            {tech}
          </span>
        ))}
      </div>
    </div>

    {/* Right: Isometric Decoration */}
    <div class="hidden lg:flex items-center justify-center relative">
      <svg viewBox="0 0 400 400" class="w-full max-w-md" xmlns="http://www.w3.org/2000/svg">
        {/* Isometric grid */}
        <g stroke="#D6D3D0" stroke-width="0.5" fill="none" opacity="0.6">
          {/* Floor grid */}
          {Array.from({ length: 9 }, (_, i) => {
            const offset = i * 30;
            return (
              <>
                <line x1={50 + offset} y1={300} x2={200 + offset} y2={210} />
                <line x1={50} y1={300 - offset} x2={200} y2={210 - offset} />
              </>
            );
          })}
        </g>

        {/* Building wireframe */}
        <g stroke="#2563EB" stroke-width="1.5" fill="none">
          {/* Main box */}
          <path d="M120,280 L120,160 L200,110 L280,160 L280,280 L200,330 Z" />
          <line x1="200" y1="110" x2="200" y2="230" />
          <line x1="120" y1="160" x2="280" y2="160" />

          {/* Roof */}
          <path d="M100,160 L200,90 L300,160" stroke="#C41E3A" stroke-width="1" />
          <line x1="200" y1="90" x2="200" y2="110" stroke="#C41E3A" stroke-width="1" />

          {/* Windows */}
          <rect x="140" y="190" width="25" height="30" stroke="#1A1A1A" stroke-width="1" opacity="0.4" />
          <rect x="180" y="175" width="25" height="30" stroke="#1A1A1A" stroke-width="1" opacity="0.4" />
          <rect x="235" y="190" width="25" height="30" stroke="#1A1A1A" stroke-width="1" opacity="0.4" />

          {/* Door */}
          <rect x="185" y="255" width="30" height="45" stroke="#1A1A1A" stroke-width="1" opacity="0.4" />
        </g>

        {/* Dimension lines */}
        <g stroke="#B8B5AF" stroke-width="0.5" fill="#6B7280" font-family="'JetBrains Mono', monospace" font-size="8">
          {/* Height */}
          <line x1="85" y1="160" x2="85" y2="280" />
          <line x1="82" y1="160" x2="88" y2="160" />
          <line x1="82" y1="280" x2="88" y2="280" />
          <text x="75" y="220" text-anchor="end">H</text>

          {/* Width */}
          <line x1="120" y1="310" x2="280" y2="310" />
          <line x1="120" y1="307" x2="120" y2="313" />
          <line x1="280" y1="307" x2="280" y2="313" />
          <text x="200" y="325" text-anchor="middle">W</text>
        </g>

        {/* Crosshair markers */}
        <g stroke="#2563EB" stroke-width="0.5" opacity="0.6">
          <line x1="195" y1="85" x2="205" y2="85" />
          <line x1="200" y1="80" x2="200" y2="90" />
        </g>

        {/* Construction lines */}
        <g stroke="#F59E0B" stroke-width="0.3" stroke-dasharray="4,4" opacity="0.4">
          <line x1="200" y1="50" x2="200" y2="350" />
          <line x1="50" y1="210" x2="350" y2="210" />
        </g>
      </svg>
    </div>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="font-mono text-xs text-text-tertiary">SCROLL</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="#9CA3AF" stroke-width="1.5">
      <path d="M8 4 L8 18 M3 14 L8 19 L13 14" />
    </svg>
  </div>
</GridBackground>
